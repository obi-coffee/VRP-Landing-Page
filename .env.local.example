# Resend — Email notifications for new VRP applications
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives new application notifications
NOTIFICATION_EMAIL=obi@tastcoffee.com

# Google Sheets — Append each submission as a row
# Create a Google Cloud service account, enable the Sheets API,
# and share the spreadsheet with the service account email.
GOOGLE_SHEETS_CLIENT_EMAIL=vrp-forms@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_from_the_url
